# Postgres connection string. Matches docker-compose.yml for local dev.
DATABASE_URL="postgres://crub:crub@localhost:5432/crubbucks"

# --- Email --------------------------------------------------------------
# Resend (https://resend.com) — used for verify-email and password reset.
# If unset, emails are logged to the server console (fine for local dev).
RESEND_API_KEY=""
# Sender address. Must be on a domain you've verified in Resend in production.
EMAIL_FROM="Crub Bucks <no-reply@crub-bucks.local>"

# --- App URL (public) --------------------------------------------------
# Used to build absolute links in emails. Must match the URL the user
# reaches the app at (origin only, no trailing slash).
PUBLIC_APP_URL="http://localhost:5173"

# --- hCaptcha ----------------------------------------------------------
# Site key is exposed to the client (must start with PUBLIC_).
# If both are unset, the captcha widget renders nothing and server-side
# verification short-circuits as "ok" — fine for local dev.
PUBLIC_HCAPTCHA_SITE_KEY=""
HCAPTCHA_SECRET=""
