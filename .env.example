# Postgres connection string.
#
# Local dev: matches docker-compose.yml.
# Production: self-hosted Postgres on the same VPS, bound to 127.0.0.1.
#   No sslmode=require (and no TLS overhead) since traffic never leaves
#   the box. See docs/deployment.md → Phase 1.2 for the install + role
#   setup and Phase 3 for the connection string.
#   Example: postgres://crubbucks:STRONG_PASSWORD@127.0.0.1:5432/crubbucks
DATABASE_URL="postgres://crub:crub@localhost:5432/crubbucks"

# --- Email --------------------------------------------------------------
# Resend (https://resend.com) — used for verify-email, password reset, and
# friend invites. If unset, emails are logged to the server console (fine
# for local dev).
RESEND_API_KEY=""
# Sender address. Must be on a domain you've verified in Resend in production;
# the dev "onboarding@resend.dev" sender only delivers to the Resend account
# owner's own address.
EMAIL_FROM="Crub Bucks <no-reply@crub-bucks.local>"
# Where user content reports (offensive bet/name) are emailed. Defaults to
# info@crubbucks.com if unset.
REPORTS_EMAIL="info@crubbucks.com"

# --- App URL (public) --------------------------------------------------
# Used to build absolute links in outbound emails. Must match the URL
# users reach the app at (origin only, no trailing slash).
PUBLIC_APP_URL="http://localhost:5173"

# --- hCaptcha ----------------------------------------------------------
# Site key is exposed to the client (must start with PUBLIC_).
#
# Three modes:
#   1. Both unset (default) — captcha widget renders nothing and server-side
#      verification short-circuits to "ok". Frictionless local dev.
#   2. hCaptcha's public test keys — widget renders, always passes, no
#      signup needed. Use these to develop the UI flow locally:
#        PUBLIC_HCAPTCHA_SITE_KEY="10000000-ffff-ffff-ffff-000000000001"
#        HCAPTCHA_SECRET="0x0000000000000000000000000000000000000000"
#      The widget will show "This is for testing only" — that's the point;
#      you'll notice if you forget to swap to real keys before deploying.
#   3. Real keys from hcaptcha.com — what production must use. Sign up,
#      add your site, copy both keys into your prod .env. Free tier is
#      generous (1M verifications/month).
PUBLIC_HCAPTCHA_SITE_KEY=""
HCAPTCHA_SECRET=""

# --- Production-only (SvelteKit adapter-node) --------------------------
# Required once TLS is on. SvelteKit compares the Origin request header to
# this value on POST form submissions; mismatch returns "Cross-site POST
# form submissions are forbidden". Set this to the public HTTPS URL after
# Let's Encrypt is provisioned, then reload PM2.
#   ORIGIN="https://crub-bucks.example.com"
ORIGIN=""

# Max request body size (bytes). Default 524288 (512 KB) is fine — Crub
# Bucks doesn't accept uploads. Bump only if you add one.
#   BODY_SIZE_LIMIT="524288"

# Node listen port. Nginx proxies 443 → this. PM2 ecosystem also sets it.
#   PORT="3000"

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
PUBLIC_VAPID_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
